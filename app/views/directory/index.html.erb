<div class="w-full max-w-4xl">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Business Directory</h1>
    <% if user_signed_in? %>
      <a href="#" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Add Your Business</a>
    <% end %>
  </div>

  <% if @businesses.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @businesses.each do |business| %>
        <div class="bg-white p-6 rounded-lg shadow border border-gray-100">
          <h2 class="text-xl font-bold text-blue-600 mb-2"><%= business.name %></h2>
          <p class="text-sm text-gray-500 mb-4"><%= business.industry %> | <%= business.location %></p>
          <p class="text-gray-700 mb-4"><%= business.description %></p>
          <div class="border-t pt-4 flex justify-between items-center">
            <span class="text-sm text-gray-600">Owner: <%= business.user.name %></span>
            <% if business.website_url.present? %>
              <%= link_to "Website", business.website_url, target: "_blank", class: "text-blue-500 hover:underline text-sm" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-50 p-12 rounded-lg text-center border-2 border-dashed border-gray-200">
      <p class="text-gray-500 text-lg italic">No businesses listed yet. Be the first to join!</p>
    </div>
  <% end %>
</div>
