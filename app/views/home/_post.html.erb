<article class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-orange-200 transition-all duration-200 overflow-hidden">
  <div class="h-1 bg-gradient-to-r from-orange-400 to-amber-400"></div>
  <div class="p-6">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-3">
        <div class="bg-gradient-to-br from-orange-400 to-amber-500 text-orange-700 rounded-full w-10 h-10 flex items-center justify-center font-bold text-base shadow-sm">
          <%= post.business.name.first.upcase %>
        </div>
        <div>
          <p class="font-semibold text-gray-900"><%= post.business.name %></p>
          <div class="flex items-center gap-2 text-sm text-gray-500">
            <span><%= post.business.industry %></span>
            <span class="text-gray-300">•</span>
            <time datetime="<%= post.created_at.iso8601 %>" class="hover:text-gray-700 cursor-default">
              <%= time_ago_in_words(post.created_at) %> ago
            </time>
          </div>
        </div>
      </div>
      <% if user_signed_in? && post.business.user == current_user %>
        <%= button_to post_path(post), method: :delete, data: { turbo_confirm: "Delete this post?" }, class: "text-gray-400 hover:text-red-500 p-1 rounded hover:bg-red-50 transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        <% end %>
      <% end %>
    </div>
    <p class="text-gray-700 whitespace-pre-wrap leading-relaxed"><%= post.content %></p>
  </div>
</article>
