<div class="max-w-6xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-6 text-center">VolleyConnect Feed</h1>

  <% if user_signed_in? %>
    <% if current_user.businesses.any? %>
      <div class="bg-white rounded-lg shadow p-4 mb-6">
        <%= form_with model: Post.new, url: posts_path, local: true, class: "flex flex-col gap-3" do |f| %>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-sm font-medium text-gray-700">Post as:</span>
            <%= f.collection_select :business_id, current_user.businesses, :id, :name, {}, class: "text-sm border border-gray-300 rounded-md p-1 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          <%= f.text_area :content, placeholder: "Share an update from your business...", rows: 3, class: "w-full border border-gray-300 rounded-lg p-3 resize-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500", required: true %>
          <div class="flex justify-end">
            <%= f.submit "Post", class: "bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 font-medium" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-yellow-700">
              You need a business profile to create posts.
              <%= link_to "Create a business", new_business_path, class: "font-medium underline hover:text-yellow-600" %>
            </p>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="bg-blue-50 rounded-lg p-4 mb-6 text-center">
      <p class="text-blue-800">
        <%= link_to "Sign in", new_user_session_path, class: "font-semibold underline" %> or
        <%= link_to "join the network", new_user_registration_path, class: "font-semibold underline" %>
        to share posts.
      </p>
    </div>
  <% end %>

  <div class="space-y-4">
    <% if @posts.any? %>
      <%= render partial: "home/post", collection: @posts, as: :post %>
    <% else %>
      <div class="text-center text-gray-500 py-8">
        <p>No posts yet. Be the first to share!</p>
      </div>
    <% end %>
  </div>
</div>
