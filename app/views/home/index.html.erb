<div class="w-full max-w-4xl mx-auto pb-16">
  <section class="text-center mb-10">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gradient-to-br from-orange-400 to-amber-500 mb-4 shadow-lg">
      <svg class="w-12 h-12 text-white" viewBox="0 0 24 24" fill="currentColor">
        <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/>
        <path d="M12 2c0 5.5-2.5 7-5 8.5S3 14 3 17.5 6 22 12 22" fill="none" stroke="currentColor" stroke-width="1.5"/>
        <path d="M12 2c0 5.5 2.5 7 5 8.5s4 3 4 6.5S18 22 12 22" fill="none" stroke="currentColor" stroke-width="1.5"/>
        <path d="M3.5 9.5C6 7 9 5 12 4s6-1 7 1.5S21 10 21 14c0 3-1.5 5.5-4.5 7.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </div>
    <h1 class="text-4xl font-bold text-gray-900 mb-2">Welcome to VolleyConnect</h1>
    <p class="text-lg text-gray-600">Connect with the volleyball community</p>
    <% unless user_signed_in? %>
      <div class="mt-6 flex justify-center gap-4">
        <%= link_to "Sign In", new_user_session_path, class: "bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 font-medium transition-colors shadow-md hover:shadow-lg" %>
        <%= link_to "Join the Network", new_user_registration_path, class: "bg-white text-blue-600 border-2 border-blue-600 px-6 py-2.5 rounded-lg hover:bg-blue-50 font-medium transition-colors" %>
      </div>
    <% end %>
  </section>

  <% if user_signed_in? %>
    <% if current_user.businesses.any? %>
      <section class="mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="bg-gradient-to-r from-orange-50 to-amber-50 px-6 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-gray-800 flex items-center gap-2">
              <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Create Post
            </h2>
          </div>
          <div class="p-6">
            <%= form_with model: Post.new, url: posts_path, local: true, class: "flex flex-col gap-5" do |f| %>
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-gray-600">Post as:</span>
                <%= f.collection_select :business_id, current_user.businesses, :id, :name, {}, class: "text-sm border border-gray-200 rounded-md px-3 py-1.5 focus:ring-2 focus:ring-blue-400 focus:border-blue-400 bg-gray-50" %>
              </div>
              <%= f.text_area :content, placeholder: "Share an update from your business...", rows: 4, class: "w-full border border-gray-200 rounded-lg p-3 resize-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400 transition-all bg-gray-50/50", required: true %>
              <div class="flex justify-end">
                <%= f.submit "Post", class: "bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 font-medium shadow-sm hover:shadow-md transition-all" %>
              </div>
            <% end %>
          </div>
        </div>
      </section>
    <% else %>
      <section class="mb-8">
        <div class="bg-amber-50 border-l-4 border-amber-400 rounded-r-lg p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-amber-800">
                You need a business profile to create posts.
                <%= link_to "Create a business", new_business_path, class: "font-semibold underline hover:text-amber-600" %>
              </p>
            </div>
          </div>
        </div>
      </section>
    <% end %>
  <% else %>
    <section class="mb-8">
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-6 text-center border border-blue-100">
        <p class="text-blue-800">
          <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <%= link_to "Sign in", new_user_session_path, class: "font-semibold underline hover:text-blue-600" %> or
          <%= link_to "join the network", new_user_registration_path, class: "font-semibold underline hover:text-blue-600" %>
          to share posts and connect with the community.
        </p>
      </div>
    </section>
  <% end %>

  <section>
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2">
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
        </svg>
        Community Feed
      </h2>
      <span class="text-sm text-gray-500"><%= @posts.count %> posts</span>
    </div>

    <div class="space-y-4">
      <% if @posts.any? %>
        <%= render partial: "home/post", collection: @posts, as: :post %>
      <% else %>
        <div class="bg-white rounded-xl border-2 border-dashed border-gray-200 p-12 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
            <svg class="w-8 h-8 text-gray-400" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 2c0 5.5-2.5 7-5 8.5S3 14 3 17.5 6 22 12 22" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-700 mb-2">No posts yet</h3>
          <p class="text-gray-500 mb-4">Be the first to share something with the community!</p>
          <% if user_signed_in? && current_user.businesses.any? %>
            <button onclick="document.querySelector('form').scrollIntoView({behavior: 'smooth'})" class="text-orange-600 hover:text-orange-700 font-medium">
              Create your first post
            </button>
          <% else %>
            <%= link_to "Explore businesses", directory_path, class: "text-blue-600 hover:text-blue-700 font-medium" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>
</div>
