<div class="w-full max-w-2xl">
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="flex items-start gap-4">
      <div class="w-20 h-20 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
        <%= @user.name.first.upcase %>
      </div>
      <div class="flex-1">
        <h1 class="text-2xl font-bold text-gray-900"><%= @user.name %></h1>
        <% if @user.home_facility.present? %>
          <p class="text-gray-600 mt-1">
            <span class="font-medium">Home Facility:</span> <%= @user.home_facility %>
          </p>
        <% end %>
      </div>
    </div>

    <% if @user.volleyball_bio.present? %>
      <div class="mt-4 pt-4 border-t border-gray-200">
        <h2 class="text-sm font-medium text-gray-700 mb-2">Volleyball Bio</h2>
        <p class="text-gray-600 whitespace-pre-wrap"><%= @user.volleyball_bio %></p>
      </div>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Posts by <%= @user.name %></h2>
    </div>
    <div class="divide-y divide-gray-200">
      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <div class="p-6">
            <p class="text-gray-800"><%= post.content %></p>
            <p class="text-sm text-gray-500 mt-2">
              <%= time_ago_in_words(post.created_at) %> ago
              <% if post.business %>
                <span class="mx-1">·</span>
                <span class="text-blue-600"><%= post.business.name %></span>
              <% end %>
            </p>
          </div>
        <% end %>
      <% else %>
        <div class="p-6 text-center text-gray-500">
          No posts yet.
        </div>
      <% end %>
    </div>
  </div>
</div>
